# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
TELEGRAM_ADMIN_USERNAMES=admin1,admin2

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDINGS_MODEL=llama3.2

# Database Configuration
DATABASE_URL=sqlite:///teiken_claw.db
DATABASE_WAL_MODE=true

# Queue Configuration
QUEUE_MAX_WORKERS=4
QUEUE_PRIORITY_LEVELS=high,normal,low
QUEUE_DEAD_LETTER_TTL=86400

# Throttling Configuration
THROTTLE_GLOBAL_LIMIT=30
THROTTLE_GLOBAL_WINDOW=60
THROTTLE_PER_CHAT_LIMIT=10
THROTTLE_PER_CHAT_WINDOW=60

# Memory Configuration
MEMORY_MAX_RECORDS=10000
MEMORY_AUTO_EXTRACT=true
MEMORY_AUTO_EXTRACT_INTERVAL=300
MEMORY_AUTO_REVIEW=false
MEMORY_AUTO_REVIEW_INTERVAL=86400

# Tool Configuration
TOOL_WEB_TIMEOUT=30
TOOL_FILES_MAX_SIZE=100MB
TOOL_EXEC_TIMEOUT=60
TOOL_EXEC_ALLOWLIST=python,powershell,curl,wget

# Scheduler Configuration
SCHEDULER_ENABLED=true
SCHEDULER_MAX_JOBS=100
SCHEDULER_JOBS_DIR=./jobs

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/teiken_claw.log

# Security Configuration
SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Development Configuration
DEBUG=false
TESTING=false
ENV=production