# =============================================================================
# Teiken Claw - Environment Configuration
# =============================================================================
# Copy this file to .env and update values as needed.
# NEVER commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_NAME=Teiken Claw
APP_DESCRIPTION=AI Agent System
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite database URL (default)
DATABASE_URL=sqlite+aiosqlite:///./data/teiken_claw.db
# Set to true to see SQL queries in logs
DATABASE_ECHO=false

# -----------------------------------------------------------------------------
# Ollama Configuration
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SEC=120
OLLAMA_MAX_CONCURRENCY=3

# -----------------------------------------------------------------------------
# Telegram Configuration
# -----------------------------------------------------------------------------
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Rate limiting (messages per second)
TELEGRAM_GLOBAL_MSG_PER_SEC=25.0
TELEGRAM_PER_CHAT_MSG_PER_SEC=1.0

# -----------------------------------------------------------------------------
# Interface Configuration
# -----------------------------------------------------------------------------
# Enable CLI interface
ENABLE_CLI=true
# Enable Telegram bot interface
ENABLE_TELEGRAM=false

# -----------------------------------------------------------------------------
# Workspace Configuration
# -----------------------------------------------------------------------------
WORKSPACE_DIR=./data/workspace
LOGS_DIR=./logs

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------
AGENT_MAX_CONCURRENT=5
AGENT_TIMEOUT=30
MAX_TOOL_TURNS=10

# -----------------------------------------------------------------------------
# Memory Configuration
# -----------------------------------------------------------------------------
AUTO_MEMORY_ENABLED=true
MEMORY_TYPE=sqlite
MEMORY_URL=sqlite:///./data/memory.db

# -----------------------------------------------------------------------------
# Queue Configuration
# -----------------------------------------------------------------------------
QUEUE_TYPE=sqlite
QUEUE_URL=sqlite:///./data/queue.db
# Maximum number of jobs in the queue
QUEUE_MAX_SIZE=1000
# Number of worker tasks
WORKER_COUNT=3
# Maximum concurrent Ollama API calls
OLLAMA_MAX_CONCURRENCY=2
# Maximum retry attempts for failed jobs
JOB_MAX_ATTEMPTS=3
# Lock timeout in seconds (for per-chat locks)
LOCK_TIMEOUT_SEC=300
# Idempotency key TTL in seconds
IDEMPOTENCY_TTL_SEC=3600

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of admin Telegram chat IDs
ADMIN_CHAT_IDS=
# Comma-separated list of allowed executables for code execution
EXEC_ALLOWLIST=python,node,powershell
# Comma-separated list of allowed domains for web search
WEB_ALLOWED_DOMAINS=wikipedia.org,github.com,stackoverflow.com

# -----------------------------------------------------------------------------
# Redis Configuration (optional)
# -----------------------------------------------------------------------------
# Uncomment to use Redis for queue/memory
# REDIS_URL=redis://localhost:6379
